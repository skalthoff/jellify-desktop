# Jellify Desktop — local development environment variables
#
# Copy this file to `.env.local` and fill in the values you need.
# Nothing in this repo auto-sources `.env.local`; load it manually with
# `set -a; source .env.local; set +a` before running tests or scripts.
#
# For CI secrets, see docs/GITHUB-SECRETS.md.


# ---- E2E tests (core/tests/e2e_live.rs) ----
# Points the live-integration test suite at a Jellyfin server.
# In CI an ephemeral Docker container is used (see .github/workflows/e2e.yml).
# Locally, run `docker run -d -p 8096:8096 jellyfin/jellyfin:10.11.8` and then
# `./Scripts/e2e-setup-jellyfin.sh http://localhost:8096 jellify-e2e jellify-e2e-password`.
JELLIFY_E2E_URL=http://localhost:8096
JELLIFY_E2E_USER=jellify-e2e
JELLIFY_E2E_PASS=jellify-e2e-password

# How many seconds to wait for the Jellyfin server to start (default: 180).
JELLIFY_E2E_WAIT_SECONDS=

# ---- CLI example (examples/cli) and macOS SmokeTest ----
# Same idea, different variable names (historical — kept for compat).
JELLYFIN_URL=http://localhost:8096
JELLYFIN_USER=jellify-e2e
JELLYFIN_PASS=jellify-e2e-password


# ---- macOS release build (local signing / notarization) ----
# Only needed for `./Scripts/sign.sh` + `./Scripts/notarize.sh` locally.

# Developer ID Application identity string, exactly as `security find-identity -v -p codesigning` shows it.
# e.g. "Developer ID Application: Your Name (ABCDE12345)"
APPLE_DEVELOPER_ID_IDENTITY=

# Your 10-character Apple Team ID (same one embedded in the identity above).
APPLE_TEAM_ID=

# Name of the notarytool keychain profile you stored with:
#   xcrun notarytool store-credentials jellify-notary --apple-id ... --team-id ... --password ...
APPLE_NOTARY_PROFILE=jellify-notary

# Alternative to APPLE_NOTARY_PROFILE: raw Apple ID + app-specific password.
# Use one or the other, not both.
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=


# ---- Sparkle auto-update (local appcast signing) ----
# Sparkle's generate_keys writes the private key into your login keychain
# by default — you only need these env vars if you want to override the
# default location (e.g. to point generate-appcast.sh at a file on disk
# for CI-style runs).

# Path to (or contents of) the EdDSA private key for signing release DMGs.
# In CI this is a GitHub secret; locally, Sparkle's keychain item covers it.
SPARKLE_ED25519_PRIVATE=

# Public key gets injected into Info.plist as SUPublicEDKey; tell
# make-bundle.sh what it is so the template substitution finds it.
SPARKLE_PUBLIC_ED_KEY=


# ---- Bundle metadata (normally derived from git) ----
# Override these if you're building from a non-tagged commit and want
# explicit values in Info.plist.
VERSION=
BUILD=


# ---- Build flags (boolean-ish) ----
# Set to "1" to have build-core.sh produce a universal (arm64 + x86_64)
# xcframework. Default (unset or "0") builds arm64-only, which is faster
# and fine for dev.
JELLIFY_UNIVERSAL=

# Override the build profile that make-bundle.sh picks up. Valid: debug, release.
JELLIFY_BUILD_CONFIG=

# Used by the release workflow to inject a CHANGELOG-derived version into
# bundle metadata. Usually unset locally.
JELLIFY_VERSION=
JELLIFY_BUILD=


# ---- System-provided, do NOT set manually ----
# HOME            — resolved by the OS.
# APPDATA         — resolved by Windows.
# XDG_DATA_HOME   — respected by core/src/storage.rs if you've already
#                   overridden it in your shell.
# CARGO_TERM_COLOR / RUST_BACKTRACE / RUSTDOCFLAGS / CARGO_INCREMENTAL
#                 — CI-only; leave alone locally.
