# Rust
target/
**/*.rs.bk

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Generated (produced by Scripts/build-core.sh)
macos/Jellify.xcframework/
macos/Sources/JellifyCore/Generated/
macos/build/

# Generated Windows artifacts (produced by windows/tools/*.ps1)
windows/Jellify.Core/Generated/*.cs
windows/Jellify.Core/native/win-x64/jellify_core.*
windows/Jellify.Core/native/win-arm64/jellify_core.*

# Visual Studio / .NET build output
windows/**/bin/
windows/**/obj/
windows/**/*.user
windows/.vs/

# Flatpak packaging (downloaded generator cache)
linux/flatpak/.cache/

# Symbol files / debug
*.pdb
*.dSYM/

# Editor + OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Claude Code workspace artifacts (batch plans, worktree metadata, etc.)
# We DO track .claude/agents/ and .claude/commands/ — they are how the
# agentic-audit pipeline ships to the team. Everything else under .claude/
# is local scratch. Pattern note: we use `.claude/*` (not `.claude/`) so
# git can re-include subdirectories via `!` exceptions below.
.claude/*
!.claude/agents/
!.claude/commands/
